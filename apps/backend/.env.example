# =============================================
# Application
# =============================================
NODE_ENV=development
PORT=3000

# =============================================
# PostgreSQL
# App runtime uses reclaim_app (non-superuser, subject to RLS).
# Migrations use reclaim (superuser).
# =============================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=reclaim_app
POSTGRES_PASSWORD=ReclaimApp2026!
POSTGRES_DB=reclaim

# =============================================
# Redis
# =============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# =============================================
# JWT Authentication
# =============================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# =============================================
# Google Document AI (OCR)
# =============================================
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=asia-southeast1
GOOGLE_DOCUMENT_AI_PROCESSOR_ID=your-processor-id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# =============================================
# Google Cloud Storage (receipt images)
# =============================================
GCS_BUCKET_NAME=your-gcs-bucket-name

# =============================================
# Encryption (AES-256-GCM for bank accounts at rest)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 64 hex chars = 32 bytes = AES-256 key
# =============================================
ENCRYPTION_KEY=generate-a-64-char-hex-string-here

# =============================================
# File Storage
# STORAGE_PROVIDER: local | spaces
#   local  — writes to UPLOADS_DIR (default /tmp/uploads). Files lost on redeploy.
#   spaces — writes to DigitalOcean Spaces. Requires DO_SPACES_* vars below.
# =============================================
STORAGE_PROVIDER=local
UPLOADS_DIR=/tmp/uploads

# DigitalOcean Spaces (required when STORAGE_PROVIDER=spaces)
DO_SPACES_ENDPOINT=https://sgp1.digitaloceanspaces.com
DO_SPACES_REGION=sgp1
DO_SPACES_BUCKET=your-space-name
DO_SPACES_ACCESS_KEY=your-spaces-access-key-id
DO_SPACES_SECRET_KEY=your-spaces-secret-access-key

# Signed URL TTL in seconds (default: 3600 = 1 hour)
STORAGE_SIGNED_URL_EXPIRY=3600

# HMAC key for fallback signed URLs served via /api/files/view
# Must be at least 32 random characters. Falls back to JWT_SECRET if unset.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
FILE_SIGNING_KEY=generate-a-64-char-hex-string-here

# =============================================
# Logging
# =============================================
LOG_LEVEL=debug
